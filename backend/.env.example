# Environnement
NODE_ENV=development
PORT=3000

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=broderie
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_32_chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (CORS)
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Facture QR suisse — IBAN de la cliente (laisser vide en dev = IBAN de test utilisé)
QR_INVOICE_IBAN=CH9300762011623852957            # IBAN de TEST — remplacer par le vrai IBAN en production
QR_INVOICE_NAME=Au Point-Compté                  # Émetteur de la facture (défaut : SHOP_NAME)
QR_INVOICE_ADDRESS=Rue de la Boutique 1
QR_INVOICE_ZIP=1200
QR_INVOICE_CITY=Genève
INVOICE_DUE_DAYS=30                              # Délai de paiement de la facture (jours)

# Click & Collect — adresse et horaires de l'unique boutique (retrait + paiement sur place)
PICKUP_NAME=Au Point-Compté                      # Défaut : SHOP_NAME
PICKUP_ADDRESS=Rue de la Boutique 1
PICKUP_ZIP=1200
PICKUP_CITY=Genève
PICKUP_HOURS=Lun–Ven 9h–18h, Sam 9h–16h

# Nodemailer (Infomaniak Mail)
MAIL_HOST=mail.infomaniak.com
MAIL_PORT=587
MAIL_USER=noreply@broderie-domaine.ch
MAIL_PASSWORD=change_me
MAIL_FROM="Broderie Shop <noreply@broderie-domaine.ch>"

# La Poste CH — Digital Commerce API (OAuth2) — démarche d'obtention : voir claude_task.md
# Tant que SWISS_POST_CLIENT_ID est vide/«change_me», le shipping tourne en mode mock (étiquettes simulées).
SWISS_POST_CLIENT_ID=change_me           # OAuth2 — créé sur developer.post.ch (produit Barcode)
SWISS_POST_CLIENT_SECRET=change_me       # OAuth2 — secret de l'application
SWISS_POST_KUNDENNUMMER=40143484         # Numéro débiteur du contrat envois La Poste (non secret)
SWISS_POST_FRANKIERNUMMER=40143484       # Numéro d'affranchissement (frankingLicense)
# Endpoints — laisser vides pour les valeurs par défaut (prod). À surcharger pour une sandbox.
# SWISS_POST_TOKEN_URL=https://api.post.ch/OAuth/token
# SWISS_POST_LABEL_URL=https://dcapi.apis.post.ch/barcode/v1/generateAddressLabel
# SWISS_POST_SCOPE=DCAPI_BARCODE_READ

# Boutique — adresse expéditeur pour les étiquettes
SHOP_NAME=Au Point-Compté
SHOP_PHONE=+41000000000
SHOP_ADDRESS=Rue de la Boutique 1
SHOP_CITY=Genève
SHOP_CANTON=GE
SHOP_ZIP=1200

# Google OAuth
GOOGLE_CLIENT_ID=change_me.apps.googleusercontent.com
MAIL_CONTACT=contact@broderie-domaine.ch

# Stockage médias — disque du VPS (backend/uploads/products/), servi par Express sous /uploads.
# Aucune variable à définir. ⚠️ Inclure backend/uploads/ dans la sauvegarde et le préserver
# lors des déploiements (ne pas le supprimer au git pull). Anciennes clés Infomaniak Cloud
# Storage abandonnées au profit du disque VPS.
