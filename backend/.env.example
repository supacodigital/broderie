# Environnement
NODE_ENV=development
PORT=3000

# Base de données MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=broderie
DB_USER=root
DB_PASSWORD=root

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_32_chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend (CORS)
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Nodemailer (Infomaniak Mail)
MAIL_HOST=mail.infomaniak.com
MAIL_PORT=587
MAIL_USER=noreply@broderie-domaine.ch
MAIL_PASSWORD=change_me
MAIL_FROM="Broderie Shop <noreply@broderie-domaine.ch>"

# ShipEngine (Swiss Post via ShipEngine)
SHIPENGINE_API_KEY=change_me
SHIPENGINE_SWISS_POST_CARRIER_ID=change_me   # ID transporteur Swiss Post dans ton compte ShipEngine

# Boutique — adresse expéditeur pour les étiquettes
SHOP_NAME=Au Point-Compté
SHOP_PHONE=+41000000000
SHOP_ADDRESS=Rue de la Boutique 1
SHOP_CITY=Genève
SHOP_CANTON=GE
SHOP_ZIP=1200

# Infomaniak Cloud Storage
STORAGE_ENDPOINT=https://s3.pub1.infomaniak.cloud
STORAGE_BUCKET=broderie-media
STORAGE_ACCESS_KEY=change_me
STORAGE_SECRET_KEY=change_me
