# ============================================================================
#  .env.production — VPS Infomaniak (Au Point-Compté)
#  Copier ce fichier en « .env.production » sur le VPS et compléter les valeurs.
#  NE JAMAIS COMMITTER le vrai .env.production (il est dans .gitignore).
#  Chargé automatiquement par app.js quand NODE_ENV=production.
# ============================================================================

NODE_ENV=production
PORT=3000

# ── Domaine (mono-domaine + Nginx) ──────────────────────────────────────────
# Frontend à la racine, admin sous /admin, API sous /api/v1 — tout sur le même host.
CLIENT_URL=https://broderie.ch
ADMIN_URL=https://broderie.ch

# ── Base de données MySQL (installée sur le VPS) ────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=broderie
DB_USER=broderie_app          # utilisateur dédié, privilèges limités (pas root)
DB_PASSWORD=__A_DEFINIR__     # mot de passe fort

# ── JWT — générer des secrets forts :  openssl rand -base64 64 ──────────────
JWT_ACCESS_SECRET=__GENERER__
JWT_REFRESH_SECRET=__GENERER__
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── MFA (TOTP) — obligatoire pour le rôle admin ─────────────────────────────
# JWT_MFA_PENDING_SECRET : générer avec  openssl rand -base64 64
#   Doit être DIFFÉRENT de JWT_ACCESS_SECRET/JWT_REFRESH_SECRET (sécurité anti-bypass).
# MFA_ENCRYPTION_KEY : générer avec  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   Exactement 64 caractères hex (32 bytes) — le serveur refuse de démarrer sinon.
JWT_MFA_PENDING_SECRET=__GENERER__
JWT_MFA_PENDING_EXPIRES_IN=5m
MFA_ENCRYPTION_KEY=__GENERER_64_CHARS_HEX__
MFA_RECOVERY_CODES_COUNT=10

# ── Stripe PRODUCTION ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live___A_DEFINIR__
STRIPE_WEBHOOK_SECRET=whsec___A_DEFINIR__   # webhook https://broderie.ch/api/v1/payments/webhook

# ── Emails — Infomaniak Mail (remplacer Mailtrap) ───────────────────────────
MAIL_HOST=mail.infomaniak.com
MAIL_PORT=587
MAIL_USER=noreply@broderie.ch
MAIL_PASSWORD=__A_DEFINIR__
MAIL_FROM="Au Point-Compté <noreply@broderie.ch>"
MAIL_CONTACT=julie@broderie.ch

# ── Facture QR suisse — ✅ valeurs réelles connues ──────────────────────────
QR_INVOICE_IBAN=__IBAN_JULIE__          # IBAN PostFinance de Julie (déjà connu, voir .env local)
QR_INVOICE_NAME=Au Point-Compté
QR_INVOICE_ADDRESS=Rue de Vuarrengel 10
QR_INVOICE_ZIP=1418
QR_INVOICE_CITY=Vuarrens
INVOICE_DUE_DAYS=30

# ── Click & Collect — ✅ valeurs réelles connues ────────────────────────────
PICKUP_NAME=Au Point-Compté
PICKUP_ADDRESS=Rue de Vuarrengel 10
PICKUP_ZIP=1418
PICKUP_CITY=Vuarrens
PICKUP_HOURS=Mardi–Samedi 9h–12h et 13h30–18h30

# ── Boutique (expéditeur étiquettes, emails) ────────────────────────────────
SHOP_NAME=Au Point-Compté
SHOP_PHONE=+41798470126
SHOP_ADDRESS=Rue de Vuarrengel 10
SHOP_CITY=Vuarrens
SHOP_CANTON=VD
SHOP_ZIP=1418

# ── La Poste CH — Digital Commerce API (étiquettes) ─────────────────────────
SWISS_POST_KUNDENNUMMER=40143484
SWISS_POST_FRANKIERNUMMER=40143484
# ⏳ Consumer Key/Secret : à coller dès l'approbation de la subscription Barcode
#    (statut PENDING). Tant qu'absents → mode mock (étiquettes simulées).
# SWISS_POST_CLIENT_ID=
# SWISS_POST_CLIENT_SECRET=

# ── Google OAuth (ajouter https://broderie.ch aux origines autorisées) ──────
GOOGLE_CLIENT_ID=__MEME_QUE_FRONTEND__.apps.googleusercontent.com

# ── Stockage médias ─────────────────────────────────────────────────────────
# Choix retenu : disque du VPS (backend/uploads/products/), servi par Express sous /uploads.
# Aucune variable à définir. ⚠️ Inclure backend/uploads/ dans la sauvegarde (Swiss Backup)
# et le préserver lors des déploiements (ne pas le supprimer au git pull).
