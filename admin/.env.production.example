# Admin (Vite) — variables de build PRODUCTION.
# Copier en « admin/.env.production » avant « npm run build ».

# Pas de VITE_API_URL : l'admin utilise /api/v1 relatif (même domaine, servi par Express)

# URL de la boutique cliente — lien « Voir la boutique » de l'admin.
# Architecture mono-domaine : la boutique est à la racine du domaine.
VITE_SHOP_URL=https://broderie.ch
