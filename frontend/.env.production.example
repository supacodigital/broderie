# Frontend (Vite) — variables de build PRODUCTION.
# Copier en « frontend/.env.production » avant « npm run build ».
# Les variables VITE_ sont injectées dans le bundle au moment du build (publiques).

# Pas de VITE_API_URL — Axios utilise /api/v1 relatif (même domaine, proxié par Express)

# Stripe — clé PUBLIQUE de production
VITE_STRIPE_PUBLIC_KEY=pk_live___A_DEFINIR__

# Google OAuth — même client ID que le backend
VITE_GOOGLE_CLIENT_ID=__MEME_QUE_BACKEND__.apps.googleusercontent.com

# URL du site — utilisée par le SEO (canonical, hreflang, Open Graph)
VITE_SITE_URL=https://broderie.ch
VITE_SHOP_URL=https://broderie.ch
